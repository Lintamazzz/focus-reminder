{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Focus Reminder",
  "version": "0.1.0",
  "identifier": "com.focusreminder.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Focus Reminder",
        "width": 820,
        "height": 680,
        "minWidth": 660,
        "minHeight": 560,
        "center": true
      },
      {
        "label": "reminder",
        "title": "Focus Reminder - 时间到了",
        "url": "index.html?window=reminder",
        "width": 560,
        "height": 590,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
